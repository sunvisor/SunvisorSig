{
  "name": "sunvisor-sig",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "wrangler d1 migrations apply sunvisor-sig --local",
    "db:purge": "tsx prisma/purge.ts",
    "db:seed": "node prisma/seed.mjs",
    "db:test-deletion": "tsx prisma/test-deletion.ts",
    "db:test-notifications": "tsx prisma/test-notifications.ts",
    "db:test-activation": "tsx prisma/test-activation.ts",
    "db:test-channel-subscriptions": "tsx prisma/test-channel-subscriptions.ts",
    "db:test-creation": "tsx prisma/test-creation.ts",
    "db:test-editing": "tsx prisma/test-editing.ts",
    "db:test-post-comment-creation": "tsx prisma/test-post-comment-creation.ts",
    "db:test-post-status": "tsx prisma/test-post-status.ts",
    "db:test-profile": "tsx prisma/test-profile.ts",
    "db:test-forum-management": "tsx prisma/test-forum-management.ts",
    "db:test-attachments": "tsx prisma/test-attachments.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^6.19.2",
    "@prisma/client": "^6.19.2",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@opennextjs/cloudflare": "^1.19.4",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.20.0",
    "eslint-config-next": "^16.0.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.85.0"
  }
}
