generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum SystemRole {
  ADMIN
  USER
}

enum ForumRole {
  PARTICIPANT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELED
}

enum DeletedAttachmentOwnerType {
  POST
  COMMENT
}

enum PostStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum CommentType {
  USER
  STATUS_CHANGE
}

enum NotificationType {
  COMMENT_ON_POST
  MENTION_IN_POST
  MENTION_IN_COMMENT
  CHANNEL_POST
  CHANNEL_COMMENT
}

enum WebhookEndpointType {
  SLACK
  DISCORD
  TEAMS
  GOOGLE_CHAT
}

enum WebhookEventType {
  POST_CREATED
  COMMENT_CREATED
  MENTIONED
  STATUS_CHANGED
}

enum AuditActionType {
  FORUM_CREATED
  FORUM_UPDATED
  FORUM_DELETED
  CHANNEL_CREATED
  CHANNEL_DELETED
  FORUM_MEMBER_ADDED
  FORUM_MEMBER_REMOVED
  INVITATION_CREATED
  INVITATION_CANCELED
  WEBHOOK_CREATED
  WEBHOOK_UPDATED
  WEBHOOK_DELETED
  WEBHOOK_TESTED
}

enum AuditTargetType {
  FORUM
  CHANNEL
  FORUM_MEMBER
  INVITATION
  WEBHOOK
}

model User {
  id                      String                @id @default(uuid())
  displayName             String
  email                   String?               @unique
  mentionHandle           String?               @unique
  passwordHash            String?
  systemRole              SystemRole            @default(USER)
  status                  UserStatus            @default(INVITED)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  createdForums           Forum[]               @relation("ForumCreator")
  createdInvitations      Invitation[]          @relation("InvitationCreator")
  forumMemberships        ForumMember[]
  createdChannels         Channel[]             @relation("ChannelCreator")
  posts                   Post[]
  comments                Comment[]
  channelSubscriptions    ChannelSubscription[]
  notifications           Notification[]        @relation("NotificationRecipient")
  notificationActors      Notification[]        @relation("NotificationActor")
  auditLogs               AuditLog[]
  createdWebhookEndpoints WebhookEndpoint[]     @relation("WebhookEndpointCreator")
}

model Forum {
  id                String            @id @default(uuid())
  name              String
  description       String?
  themeName         String            @default("Ocean")
  themeAccent       String            @default("#0f766e")
  themeAccentSoft   String            @default("#ccfbf1")
  themeSurface      String            @default("#ffffff")
  themeSurfaceMuted String            @default("#f8fafc")
  themeBorder       String            @default("#cbd5e1")
  themeText         String            @default("#0f172a")
  themeTextMuted    String            @default("#475569")
  themeTextSubtle   String            @default("#94a3b8")
  themePageFrom     String            @default("#f8fafc")
  themePageTo       String            @default("#eff6ff")
  createdByUserId   String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  createdByUser     User              @relation("ForumCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  members           ForumMember[]
  channels          Channel[]
  invitations       Invitation[]
  webhookEndpoints  WebhookEndpoint[]
}

model Invitation {
  id              String           @id @default(uuid())
  forumId         String
  email           String
  role            ForumRole        @default(PARTICIPANT)
  token           String           @unique
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  canceledAt      DateTime?
  createdByUserId String
  createdAt       DateTime         @default(now())
  forum           Forum            @relation(fields: [forumId], references: [id], onDelete: Cascade)
  createdByUser   User             @relation("InvitationCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([forumId, status])
  @@index([email])
}

model ForumMember {
  id       String    @id @default(uuid())
  forumId  String
  userId   String
  role     ForumRole @default(PARTICIPANT)
  joinedAt DateTime  @default(now())
  forum    Forum     @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([forumId, userId])
}

model Channel {
  id              String                @id @default(uuid())
  forumId         String
  name            String
  description     String?
  createdByUserId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  forum           Forum                 @relation(fields: [forumId], references: [id], onDelete: Cascade)
  createdByUser   User                  @relation("ChannelCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  posts           Post[]
  subscriptions   ChannelSubscription[]

  @@unique([forumId, name])
}

model ChannelSubscription {
  id        String   @id @default(uuid())
  channelId String
  userId    String
  createdAt DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model Post {
  id            String           @id @default(uuid())
  channelId     String
  authorUserId  String
  title         String
  bodyMarkdown  String
  status        PostStatus?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  channel       Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorUser    User             @relation(fields: [authorUserId], references: [id], onDelete: Restrict)
  attachments   PostAttachment[]
  comments      Comment[]
  notifications Notification[]
}

model PostAttachment {
  id               String   @id @default(uuid())
  postId           String
  storagePath      String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime @default(now())
  post             Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, originalFilename])
}

model Comment {
  id            String              @id @default(uuid())
  postId        String
  authorUserId  String
  type          CommentType         @default(USER)
  bodyMarkdown  String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  post          Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorUser    User                @relation(fields: [authorUserId], references: [id], onDelete: Restrict)
  attachments   CommentAttachment[]
  notifications Notification[]
}

model CommentAttachment {
  id               String   @id @default(uuid())
  commentId        String
  storagePath      String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime @default(now())
  comment          Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, originalFilename])
}

model DeletedPost {
  id              String   @id @default(uuid())
  originalPostId  String   @unique
  channelId       String
  authorUserId    String
  title           String
  bodyMarkdown    String
  deletedByUserId String?
  deletedAt       DateTime @default(now())
  purgeAfter      DateTime
  createdAt       DateTime
}

model DeletedComment {
  id                String      @id @default(uuid())
  originalCommentId String      @unique
  postId            String
  authorUserId      String
  type              CommentType @default(USER)
  bodyMarkdown      String
  deletedByUserId   String?
  deletedAt         DateTime    @default(now())
  purgeAfter        DateTime
  createdAt         DateTime
}

model DeletedAttachment {
  id                   String                     @id @default(uuid())
  originalAttachmentId String                     @unique
  ownerType            DeletedAttachmentOwnerType
  ownerId              String
  storagePath          String
  originalFilename     String
  mimeType             String
  sizeBytes            Int
  deletedAt            DateTime                   @default(now())
  purgeAfter           DateTime
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  postId      String
  commentId   String?
  actorUserId String
  type        NotificationType
  message     String
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  user        User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  post        Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment     Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  actorUser   User             @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([userId, readAt, createdAt])
  @@index([postId])
}

model AuditLog {
  id          String          @id @default(uuid())
  actorUserId String
  actionType  AuditActionType
  targetType  AuditTargetType
  targetId    String
  targetLabel String
  metadata    Json?
  createdAt   DateTime        @default(now())
  actorUser   User            @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([actionType, createdAt])
  @@index([actorUserId, createdAt])
}

model WebhookEndpoint {
  id              String              @id @default(uuid())
  forumId         String
  name            String
  type            WebhookEndpointType
  webhookUrl      String
  eventsJson      String              @default("[]")
  enabled         Boolean             @default(true)
  createdByUserId String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  forum           Forum               @relation(fields: [forumId], references: [id], onDelete: Cascade)
  createdByUser   User                @relation("WebhookEndpointCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([forumId, enabled, type])
}
