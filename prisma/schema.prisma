generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum SystemRole {
  ADMIN
  USER
}

enum ForumRole {
  PARTICIPANT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELED
}

enum DeletedAttachmentOwnerType {
  POST
  COMMENT
}

enum PostStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum CommentType {
  USER
  STATUS_CHANGE
}

enum NotificationType {
  COMMENT_ON_POST
  MENTION_IN_POST
  MENTION_IN_COMMENT
}

model User {
  id                 String         @id @default(uuid()) @db.Uuid
  displayName        String
  email              String?        @unique
  mentionHandle      String?        @unique
  passwordHash       String?
  systemRole         SystemRole     @default(USER)
  status             UserStatus     @default(INVITED)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  createdForums      Forum[]        @relation("ForumCreator")
  createdInvitations Invitation[]   @relation("InvitationCreator")
  forumMemberships   ForumMember[]
  createdChannels    Channel[]      @relation("ChannelCreator")
  posts              Post[]
  comments           Comment[]
  notifications      Notification[] @relation("NotificationRecipient")
  notificationActors Notification[] @relation("NotificationActor")
}

model Forum {
  id                String        @id @default(uuid()) @db.Uuid
  name              String
  description       String?
  themeName         String        @default("Ocean")
  themeAccent       String        @default("#0f766e")
  themeAccentSoft   String        @default("#ccfbf1")
  themeSurface      String        @default("#ffffff")
  themeSurfaceMuted String        @default("#f8fafc")
  themeBorder       String        @default("#cbd5e1")
  themeText         String        @default("#0f172a")
  themeTextMuted    String        @default("#475569")
  themeTextSubtle   String        @default("#94a3b8")
  themePageFrom     String        @default("#f8fafc")
  themePageTo       String        @default("#eff6ff")
  createdByUserId   String        @db.Uuid
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  createdByUser     User          @relation("ForumCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  members           ForumMember[]
  channels          Channel[]
  invitations       Invitation[]
}

model Invitation {
  id              String           @id @default(uuid()) @db.Uuid
  forumId         String           @db.Uuid
  email           String
  role            ForumRole        @default(PARTICIPANT)
  token           String           @unique
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  canceledAt      DateTime?
  createdByUserId String           @db.Uuid
  createdAt       DateTime         @default(now())
  forum           Forum            @relation(fields: [forumId], references: [id], onDelete: Cascade)
  createdByUser   User             @relation("InvitationCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([forumId, status])
  @@index([email])
}

model ForumMember {
  id       String    @id @default(uuid()) @db.Uuid
  forumId  String    @db.Uuid
  userId   String    @db.Uuid
  role     ForumRole @default(PARTICIPANT)
  joinedAt DateTime  @default(now())
  forum    Forum     @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([forumId, userId])
}

model Channel {
  id              String   @id @default(uuid()) @db.Uuid
  forumId         String   @db.Uuid
  name            String
  description     String?
  createdByUserId String   @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  forum           Forum    @relation(fields: [forumId], references: [id], onDelete: Cascade)
  createdByUser   User     @relation("ChannelCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  posts           Post[]

  @@unique([forumId, name])
}

model Post {
  id            String           @id @default(uuid()) @db.Uuid
  channelId     String           @db.Uuid
  authorUserId  String           @db.Uuid
  title         String
  bodyMarkdown  String           @db.Text
  status        PostStatus?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  channel       Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorUser    User             @relation(fields: [authorUserId], references: [id], onDelete: Restrict)
  attachments   PostAttachment[]
  comments      Comment[]
  notifications Notification[]
}

model PostAttachment {
  id               String   @id @default(uuid()) @db.Uuid
  postId           String   @db.Uuid
  storagePath      String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime @default(now())
  post             Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, originalFilename])
}

model Comment {
  id            String              @id @default(uuid()) @db.Uuid
  postId        String              @db.Uuid
  authorUserId  String              @db.Uuid
  type          CommentType         @default(USER)
  bodyMarkdown  String              @db.Text
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  post          Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorUser    User                @relation(fields: [authorUserId], references: [id], onDelete: Restrict)
  attachments   CommentAttachment[]
  notifications Notification[]
}

model CommentAttachment {
  id               String   @id @default(uuid()) @db.Uuid
  commentId        String   @db.Uuid
  storagePath      String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime @default(now())
  comment          Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, originalFilename])
}

model DeletedPost {
  id              String   @id @default(uuid()) @db.Uuid
  originalPostId  String   @unique @db.Uuid
  channelId       String   @db.Uuid
  authorUserId    String   @db.Uuid
  title           String
  bodyMarkdown    String   @db.Text
  deletedByUserId String?  @db.Uuid
  deletedAt       DateTime @default(now())
  purgeAfter      DateTime
  createdAt       DateTime
}

model DeletedComment {
  id                String      @id @default(uuid()) @db.Uuid
  originalCommentId String      @unique @db.Uuid
  postId            String      @db.Uuid
  authorUserId      String      @db.Uuid
  type              CommentType @default(USER)
  bodyMarkdown      String      @db.Text
  deletedByUserId   String?     @db.Uuid
  deletedAt         DateTime    @default(now())
  purgeAfter        DateTime
  createdAt         DateTime
}

model DeletedAttachment {
  id                   String                     @id @default(uuid()) @db.Uuid
  originalAttachmentId String                     @unique @db.Uuid
  ownerType            DeletedAttachmentOwnerType
  ownerId              String                     @db.Uuid
  storagePath          String
  originalFilename     String
  mimeType             String
  sizeBytes            Int
  deletedAt            DateTime                   @default(now())
  purgeAfter           DateTime
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @db.Uuid
  postId      String           @db.Uuid
  commentId   String?          @db.Uuid
  actorUserId String           @db.Uuid
  type        NotificationType
  message     String
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  user        User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  post        Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment     Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  actorUser   User             @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([userId, readAt, createdAt])
  @@index([postId])
}
